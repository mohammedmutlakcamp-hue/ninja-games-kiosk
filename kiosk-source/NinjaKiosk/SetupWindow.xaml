<Window x:Class="NinjaKiosk.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ninja Games - PC Setup"
        Width="500" Height="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#1a1a2e">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
            <!-- Logo -->
            <TextBlock Text="NINJA GAMES" FontSize="36" FontWeight="Bold"
                       Foreground="#00FF88" HorizontalAlignment="Center" FontFamily="Segoe UI"
                       Margin="0,0,0,10"/>
            <TextBlock Text="PC Setup" FontSize="18" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,30" FontFamily="Segoe UI"/>

            <!-- PC Name -->
            <TextBlock Text="PC Name" Foreground="White" FontSize="14"
                       Margin="0,0,0,8" FontFamily="Segoe UI"/>
            <TextBox x:Name="TxtPcName" FontSize="16" Padding="10,8"
                     Background="#2a2a4a" Foreground="White" BorderBrush="#00FF88"
                     BorderThickness="1" FontFamily="Segoe UI"
                     Text="PC-01"/>

            <TextBlock Text="e.g. PC-01, PC-02, VIP-01" Foreground="Gray" FontSize="11"
                       Margin="0,5,0,20" FontFamily="Segoe UI"/>

            <!-- Station ID (auto-generated from name) -->
            <TextBlock Text="Station ID (auto)" Foreground="Gray" FontSize="12"
                       Margin="0,0,0,5" FontFamily="Segoe UI"/>
            <TextBlock x:Name="TxtStationId" Text="pc-01" Foreground="#00FF88" FontSize="14"
                       Margin="0,0,0,25" FontFamily="Segoe UI"/>

            <!-- Error message -->
            <TextBlock x:Name="TxtError" Text="" Foreground="#FF4444" FontSize="12"
                       Margin="0,0,0,10" FontFamily="Segoe UI" TextWrapping="Wrap"/>

            <!-- Save button -->
            <Button x:Name="BtnSave" Content="Register &amp; Start Kiosk" FontSize="16"
                    Padding="15,10" Background="#00FF88" Foreground="#1a1a2e"
                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                    FontFamily="Segoe UI" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
