<Window x:Class="NinjaKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Ninja Games Kiosk"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black">
    <Grid>
        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay" Background="Black" Panel.ZIndex="10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="NINJA GAMES" FontSize="48" FontWeight="Bold"
                           Foreground="#00FF88" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                <TextBlock x:Name="LoadingText" Text="Connecting..." FontSize="18" Foreground="Gray"
                           HorizontalAlignment="Center" Margin="0,20,0,0" FontFamily="Segoe UI"/>
                <TextBlock x:Name="LoadingMode" Text="" FontSize="12" Foreground="#39FF14"
                           HorizontalAlignment="Center" Margin="0,8,0,0" FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- WebView2 browser -->
        <wv2:WebView2 x:Name="WebView"
                       DefaultBackgroundColor="Black"/>
    </Grid>
</Window>
